# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/tests/kicad_samples/
.pytest_cache/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.codex-artifacts/
.modumake/
.venv/
/downloads/
/tmp/
__pycache__/
*.py[cod]

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pykicadapi/agents/hook_logs/
pykicadapi/agents/security_logs/

# local ML artifacts
*.pth
*.pt
*.onnx
*.ckpt

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated wasm glue
/src/generated/modumake-kernel/
