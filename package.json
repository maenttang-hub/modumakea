{
  "name": "modumake",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:compile-server": "node ./services/compile-server/server.mjs",
    "dev:sandbox-launcher": "node ./services/sandbox-launcher/server.mjs",
    "dev:sandbox-launcher-worker": "node ./services/sandbox-launcher/run-worker.mjs",
    "build:sandbox-runtime-image": "docker build --build-arg INSTALL_ESP32_CORE=false -f ./services/sandbox-runtime/Dockerfile -t modumake/compile-sandbox-runtime:local .",
    "build:sandbox-runtime-image:full": "docker build --build-arg INSTALL_ESP32_CORE=true -f ./services/sandbox-runtime/Dockerfile -t modumake/compile-sandbox-runtime:full .",
    "dev:compile-worker": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/run-compile-sandbox-worker.ts",
    "dev:stack": "node ./scripts/dev-stack.mjs",
    "build": "next build",
    "build:rust-kernel": "node ./scripts/build-rust-kernel.mjs",
    "catalog:export-static": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/component-catalog/export-static-catalog.ts",
    "catalog:seed": "npm run catalog:export-static -- ./scripts/component-catalog/generated/static-component-catalog.json && python3 ./scripts/component-catalog/catalog_to_supabase.py ./scripts/component-catalog/generated/static-component-catalog.json --output ./scripts/component-catalog/generated/components_master.jsonl",
    "db:seed": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/seed-supabase.ts",
    "db:seed:dry": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/seed-supabase.ts --dry-run",
    "db:seed:components:sql": "npm run catalog:export-static -- ./scripts/component-catalog/generated/static-component-catalog.json && python3 ./scripts/component-catalog/catalog_to_supabase.py ./scripts/component-catalog/generated/static-component-catalog.json --table components --format sql --output ./scripts/component-catalog/generated/components.import.sql",
    "db:bootstrap:sql": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/build-supabase-bootstrap-sql.ts",
    "datasheet:board": "python3 ./scripts/datasheet-scraper/datasheet_to_board.py",
    "kicad:golden:build": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/build-clean-kicad-golden-corpus.ts",
    "kicad:golden:export-svg": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/export-clean-kicad-golden-corpus-svg.ts",
    "kicad:interpret:compare": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/kicad-interpretation-compare.ts",
    "kicad:diff:render-report": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/kicad-render-report-diff.ts",
    "kicad:scan:regression": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/kicad-regression-scan.ts",
    "kicad:parse-sym": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/kicad-sym-parser.mjs",
    "test:parser": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/kicad-parser-stress.ts",
    "test:kicad:real": "MODUMAKE_REAL_FIXTURES=1 node --test --experimental-strip-types --import ./tests/register-alias-loader.mjs ./tests/kicad-real-projects.test.ts ./tests/real-board-netlist-validation.test.ts",
    "libraries:seed:index": "node --experimental-strip-types --import ./tests/register-alias-loader.mjs ./scripts/library-catalog/seed-arduino-index.ts",
    "start": "next start",
    "lint": "eslint",
    "lint:launch-desk": "eslint src/app/api/launch-desk/route.ts src/app/launch-desk/layout.tsx src/app/launch-desk/page.tsx src/components/launch-desk/launch-desk-app.tsx src/lib/launch-desk/*.ts tests/launch-desk-tools.test.ts",
    "test": "node --test --experimental-strip-types --import ./tests/register-alias-loader.mjs ./tests/*.test.ts",
    "test:e2e": "playwright test",
    "test:validation:baseline": "bash ./scripts/ci-validation-baseline.sh",
    "test:validation:extended": "bash ./scripts/ci-validation-extended.sh",
    "test:launch-desk": "node --test --experimental-strip-types --import ./tests/register-alias-loader.mjs ./tests/launch-desk-tools.test.ts",
    "test:coverage": "node --test --experimental-strip-types --experimental-test-coverage --import ./tests/register-alias-loader.mjs ./tests/*.test.ts",
    "verify:launch-desk-stream": "node ./scripts/verify-launch-desk-stream.mjs",
    "example:blink": "node -e \"console.log('examples/blink-uno.modumake.json\\nexamples/blink-uno.ino')\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@base-ui/react": "^1.5.0",
    "@monaco-editor/react": "^4.7.0",
    "@openai/agents": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "openai": "^6.45.0",
    "playwright": "^1.61.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.11.2",
    "react-syntax-highlighter": "^16.1.1",
    "reactflow": "^11.11.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
