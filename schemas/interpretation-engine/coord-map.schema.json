{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modumake.local/schemas/interpretation-engine/coord-map.schema.json",
  "title": "CoordMap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "scale_px_per_mm",
    "origin_offset_px",
    "image_size_px",
    "sheet_size_mm"
  ],
  "properties": {
    "scale_px_per_mm": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "origin_offset_px": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 2,
      "maxItems": 2
    },
    "image_size_px": {
      "type": "array",
      "items": { "type": "integer", "minimum": 1 },
      "minItems": 2,
      "maxItems": 2
    },
    "sheet_size_mm": {
      "type": "array",
      "items": { "type": "number", "exclusiveMinimum": 0 },
      "minItems": 2,
      "maxItems": 2
    }
  }
}
